# mykeyvault — Umgebungsvariablen
# Kopieren nach .env und Werte eintragen (die .env wird NICHT synchronisiert)

# API-Token für vault-api (generieren: openssl rand -base64 32)
VAULT_API_TOKEN=changeme

# Bitwarden API-Key (aus Vaultwarden Account-Einstellungen)
BW_CLIENTID=
BW_CLIENTSECRET=

# Vaultwarden Master-Passwort (zum Unlock)
BW_PASSWORD=
